# Required
DISCORD_TOKEN=
OPENROUTER_API_KEY=

# Optional: Override the default model (google/gemini-2.5-flash)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Owner Discord user ID — unlocks unrestricted shell access, bypasses permission checks
# Get your ID: Discord Settings > Advanced > Developer Mode, then right-click your name > Copy User ID
# OWNER_ID=123456789012345678

# Optional: Cloudflare (for Pages/Workers deploy via wrangler)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
